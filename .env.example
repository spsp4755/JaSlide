# Database (replace POSTGRES_PASSWORD before deployment)
POSTGRES_USER="jaslide"
POSTGRES_PASSWORD="replace-with-a-long-random-password"
POSTGRES_DB="jaslide"
DATABASE_URL="postgresql://jaslide:replace-with-a-long-random-password@localhost:5432/jaslide?schema=public"
REDIS_URL="redis://localhost:6379"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Internal LLM (OpenAI-compatible, Ollama, or vLLM)
# Configure an active LLM model in the admin UI with this endpoint/model, or
# provide these defaults for a single internal endpoint.
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_BASE_URL="http://llm.internal:8000/v1"

# JaSlide session and Keycloak SSO
JWT_SECRET="replace-with-a-long-random-secret"
KEYCLOAK_ISSUER="https://keycloak.internal/realms/jaslide"
KEYCLOAK_CLIENT_ID="jaslide-web"
KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_REDIRECT_URI="https://jaslide.internal/api/auth/keycloak/callback"
KEYCLOAK_ADMIN_ROLES="jaslide-admin"

# Storage (AWS S3)
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Python Renderer Service
RENDERER_URL="http://localhost:8000"

# Credits
DEFAULT_FREE_CREDITS=100
CREDIT_PER_SLIDE=1
CREDIT_PER_IMAGE=5
CREDIT_PER_CHART=2
